    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/validator": "^13.15.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.2",
